# ═══════════════════════════════════════════════════════════════════
# Jarvis — Environment Configuration
# ═══════════════════════════════════════════════════════════════════
# Copy this file to `.env` and fill in your values.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ─── LLM Provider ───────────────────────────────────────────────
# Which LLM backend to use: "ollama" | "gemini" | "grok"
LLM_PROVIDER=gemini

# ─── Ollama (Local) ─────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma:2b

# ─── Google Gemini ───────────────────────────────────────────────
# Get your key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ─── Groq Cloud (LLM inference) ─────────────────────────────────────
# Get your key: https://console.groq.com/
# Note: Groq Whisper STT is optional (local Faster-Whisper is primary)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Speech-to-Text (STT) ────────────────────────────────────────
# Provider: "local" (Faster-Whisper, unlimited) | "groq" | "gemini" | "auto"
# Default: "local" — uses local Faster-Whisper for speech transcription
STT_PROVIDER=local
# Optional: Model size for local Faster-Whisper
# "tiny", "small.en" (default - English), "base.en", "small" (multilingual)
STT_MODEL_SIZE=small.en

# ─── Wake Word (Porcupine) ──────────────────────────────────────
PORCUPINE_ACCESS_KEY=your-porcupine-key-here
PORCUPINE_MODEL_PATH=
