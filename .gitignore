# ═══════════════════════════════════════════════════════════════
# Jarvis / Antigravity — .gitignore
# ═══════════════════════════════════════════════════════════════

# ─── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/
eggs/
*.whl

# ─── Virtual Environment ────────────────────────────────────────
.venv/
venv/
ENV/

# ─── PyInstaller / Build ────────────────────────────────────────
build/
*.manifest
*.spec

# ─── IDE / Tooling ──────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.gemini/
.blackboxcli/
.pytest_cache/

# ─── OS ─────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
.DS_Store

# ─── Secrets ────────────────────────────────────────────────────
.env

# ─── ML Model Artifacts (NEVER commit weights) ──────────────────
output/
llama.cpp/
*.gguf
*.safetensors
*.bin
*.pt
*.pth
*.onnx
*.tflite

# ─── Audio / TTS Temp ───────────────────────────────────────────
*.wav
*.mp3
temp_tts.*
Jarvis/temp_tts/

# ─── Logs ───────────────────────────────────────────────────────
logs/
*.log
Jarvis/logs/
Jarvis/crash.log

# ─── Workspace (sandbox) ────────────────────────────────────────
workspace/

# ─── Root-level scratch & session artifacts ─────────────────────
COMPLETION_SUMMARY.txt
STEP8_FINAL_SUMMARY.txt
system_prompt_debug.txt
example.txt
test_output.txt
image-1.png
run_test.bat

# ─── Raw Modelfile (keep Modelfile.jarvis) ──────────────────────
Modelfile
